{% doc %}
  @prompt
    imagen simple
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-simple-image-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-simple-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-simple-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-simple-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-simple-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-simple-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-simple-image-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-simple-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-simple-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
      >
    {% else %}
      <div class="ai-simple-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-simple-image-empty-state-{{ ai_gen_id }}">
          Selecciona una imagen
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Imagen simple",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Relación de aspecto",
      "options": [
        {
          "value": "1/1",
          "label": "Cuadrado (1:1)"
        },
        {
          "value": "4/3",
          "label": "Horizontal (4:3)"
        },
        {
          "value": "16/9",
          "label": "Panorámico (16:9)"
        },
        {
          "value": "3/4",
          "label": "Vertical (3:4)"
        },
        {
          "value": "2/3",
          "label": "Retrato (2:3)"
        }
      ],
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radio de borde",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Imagen simple"
    }
  ]
}
{% endschema %}
